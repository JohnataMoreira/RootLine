import { test, expect } from '@playwright/test'

test.describe.serial('Onboarding Flow', () => {
    // Generate a unique family name for this test run
    const familyName = `[E2E] Test Family ${Date.now()}`

    test('successfully creates a new family and redirects to timeline', async ({ page }) => {
        // Go to onboarding
        await page.goto('/onboarding')

        // Wait for page to load by waiting for the form input
        const nameInput = page.locator('input[name="familyName"]')
        await expect(nameInput).toBeVisible()

        // Fill out the "Create New Family" form
        await nameInput.fill(familyName)

        // Submit
        await page.locator('button[type="submit"]').click()

        // Verify redirect to timeline
        await expect(page).toHaveURL(/.*\/timeline/)

        // Open family selector to verify it was active and added
        await page.goto('/families')
        await expect(page.getByText(familyName)).toBeVisible()
    })
})
