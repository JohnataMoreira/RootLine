# Variáveis de Ambiente do RootLine
# ATENÇÃO: NUNCA armazene senhas reais neste arquivo.

NODE_ENV=development
PORT=3000

# Banco de Dados
DATABASE_URL="postgres://user:password@localhost:5432/rootline_db"

# Autenticação e APIs Externas
JWT_SECRET="mock_jwt_secret_change_in_production"
REST_API_KEY="mock_api_key_here"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Google Photos OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/google/callback (dev)
#                          https://app.rootline.com/api/google/callback (prod)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# Google Photos import settings (optional)
GOOGLE_IMPORT_LIMIT="200"
